{
  "name": "poli-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @poli-erp/api dev",
    "dev:web": "pnpm --filter @poli-erp/web dev",
    "build": "turbo build",
    "build:api": "pnpm --filter @poli-erp/api build",
    "build:web": "pnpm --filter @poli-erp/web build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @poli-erp/database generate",
    "db:migrate": "pnpm --filter @poli-erp/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @poli-erp/database migrate:deploy",
    "db:reset": "pnpm --filter @poli-erp/database migrate:reset",
    "db:seed": "pnpm --filter @poli-erp/database seed",
    "db:studio": "pnpm --filter @poli-erp/database studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
