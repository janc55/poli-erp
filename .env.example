# ─── Database (PostgreSQL local — pgAdmin) ──────────────────
# Ajusta usuario, contraseña y nombre de BD a los que hayas creado
# en tu servidor PostgreSQL local. Formato:
#   postgresql://USUARIO:PASSWORD@HOST:PUERTO/BD?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/poli_erp?schema=public"

# ─── Redis (opcional — solo si activas cache/BullMQ más adelante) ─
# Si no vas a usar Redis, déjala comentada.
# REDIS_URL="redis://localhost:6379"

# ─── API (NestJS) ───────────────────────────────────────
API_PORT=3001
API_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Web (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"

# ─── Storage (S3-compatible, futuro) ─────────────────────
S3_BUCKET="poli-erp-documents"
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ─── Notificaciones (futuro) ─────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@unior.local"
